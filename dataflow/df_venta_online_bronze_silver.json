{
	"name": "df_venta_online_bronze_silver",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ventas_online_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ventas_sc_limpia_csv",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "select1"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "derivedColumn4"
				},
				{
					"name": "filter1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          order_id as string,",
				"          timestamp as string,",
				"          product as string,",
				"          qty as string,",
				"          unit_price as string,",
				"          {customer/name} as string,",
				"          {customer/email} as string,",
				"          {customer/city} as string,",
				"          payment_method as string,",
				"          status as string,",
				"          shipping_cost as string,",
				"          channel as string,",
				"          customer as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 select(mapColumn(",
				"          id_venta = order_id,",
				"          fecha = timestamp,",
				"          producto = product,",
				"          cantidad = qty,",
				"          precio_unitario = unit_price,",
				"          cliente_nombre = {customer/name},",
				"          cliente_email = {customer/email},",
				"          ciudad = {customer/city},",
				"          metodo_pago = payment_method,",
				"          estado = status,",
				"          costo_envio = shipping_cost,",
				"          canal = channel,",
				"          cliente = customer",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 derive(id_venta = trim(id_venta),",
				"          fecha = trim(fecha),",
				"          producto = trim(producto),",
				"          cantidad = trim(cantidad),",
				"          precio_unitario = trim(precio_unitario),",
				"          nombre_cliente = trim(cliente_nombre),",
				"          cliente_email = trim(cliente_email),",
				"          ciudad = trim(ciudad),",
				"          metodo_pago = trim(metodo_pago),",
				"          estado = trim(estado),",
				"          costo_envio = trim(costo_envio),",
				"          canal = trim(canal),",
				"          cliente = trim(cliente)) ~> derivedColumn1",
				"derivedColumn1 derive(ciudad = iif(\r",
				"    in(['LPZ','La Paz','LP','la paz','LA PAZ','lapaz','Lp'], ciudad),\r",
				"    'La Paz',\r",
				"\r",
				"iif(\r",
				"    in(['CBBA','Cochabamba','cochabamba','cbba'], ciudad),\r",
				"    'Cochabamba',\r",
				"\r",
				"iif(\r",
				"    in(['SCZ','Santa Cruz','santa cruz','scz'], ciudad),\r",
				"    'Santa Cruz',\r",
				"\r",
				"iif(\r",
				"    in(['Tarija','tarija'], ciudad),\r",
				"    'Tarija',\r",
				"\r",
				"iif(\r",
				"    in(['Oruro','oruro'], ciudad),\r",
				"    'Oruro',\r",
				"\r",
				"iif(\r",
				"    in(['Potosi','potosi'], ciudad),\r",
				"    'Potosi',\r",
				"\r",
				"iif(\r",
				"    in(['Sucre','sucre'], ciudad),\r",
				"    'Sucre',\r",
				"\r",
				"iif(\r",
				"    in(['Trinidad','trinidad'], ciudad),\r",
				"    'Trinidad',\r",
				"\r",
				"iif(\r",
				"    in(['Cobija','cobija'], ciudad),\r",
				"    'Cobija',\r",
				"\r",
				"ciudad\r",
				")))))))))) ~> derivedColumn2",
				"derivedColumn2 derive(fecha = coalesce(\r",
				"    toDate(fecha,'yyyy-MM-dd'),\r",
				"    toDate(fecha,'yyyy/MM/dd'),\r",
				"\r",
				"    toDate(fecha,'dd/MM/yyyy'),\r",
				"    toDate(fecha,'dd-MM-yyyy'),\r",
				"\r",
				"    toDate(fecha,'MM/dd/yyyy'),\r",
				"    toDate(fecha,'MM-dd-yyyy'),\r",
				"\r",
				"    toDate(fecha,'dd-MMM-yyyy'),\r",
				"    toDate(fecha,'dd/MMM/yyyy'),\r",
				"\r",
				"    toDate(fecha,'MMMM dd, yyyy'),\r",
				"    toDate(fecha,'MMM dd, yyyy'),\r",
				"\r",
				"    toDate(fecha,'dd MMMM yyyy'),\r",
				"    toDate(fecha,'dd MMM yyyy'),\r",
				"\r",
				"    toDate(replace(fecha,' de ',' '),'dd MMMM yyyy'),\r",
				"    toDate(replace(fecha,' de ',' '),'dd MMM yyyy')\r",
				")) ~> derivedColumn3",
				"derivedColumn3 derive(cantidad = toInteger(cantidad),",
				"          precio_unitario = toFloat(regexReplace(toString(precio_unitario),'[^0-9.]',''))) ~> derivedColumn4",
				"derivedColumn4 filter(cantidad>0 && !isNull(precio_unitario) &&!isNull(fecha)) ~> filter1",
				"filter1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['ventas_online_limpio.csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}